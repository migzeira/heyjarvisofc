# URL pública do servidor onde o Evolution API vai rodar
# Exemplo: https://evolution.seudominio.com
EVOLUTION_SERVER_URL=https://evolution.seudominio.com

# Chave de API — escolha uma string aleatória e segura (mínimo 32 chars)
EVOLUTION_API_KEY=sua_chave_secreta_aqui_minimo_32_chars

# URL da Edge Function no Supabase que vai receber as mensagens
# Formato: https://<project-id>.supabase.co/functions/v1/whatsapp-webhook
SUPABASE_WEBHOOK_URL=https://fnilyapvhhygfzcdxqjm.supabase.co/functions/v1/whatsapp-webhook
